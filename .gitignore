# GitHub: file .gitignore per progetto (Python / ML / general)
# Ignora file temporanei, virtualenv, dati, pesi modelli, credenziali, IDE settings, cache

# Byte-compiled / caches
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache
.codex

# Virtual environments
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/
datatrove_venv/

# Python packaging / build
build/
dist/
*.egg-info/
pip-wheel-metadata/

# Test / tooling caches
.pytest_cache/
pytest_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data / artifacts / models (non condividere file di training o pesi)
# data/
# datasets/
# data_raw/
# data_processed/
# results/
# checkpoints/
# *.ckpt
# *.pth
# *.pt
# *.bin
# models/
output
logs

# Hugging Face / caches
.cache/
.huggingface/
transformers_cache/
torch_cache/

# Secrets / environment
.env
.env.*
credentials.json

# IDEs / editors
.vscode/

# Optional: evita di committare file di config locali
config/stefano.conf
config/silvio.conf
config/gabriele.conf